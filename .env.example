# Scorpio Analyst — environment variable overrides
# Copy to .env and fill in real values. Never commit .env to version control.

# LLM Provider Keys
SCORPIO_OPENAI_API_KEY=sk-your-key-here
SCORPIO_ANTHROPIC_API_KEY=sk-ant-your-key-here
SCORPIO_GEMINI_API_KEY=your-gemini-key-here
SCORPIO_OPENROUTER_API_KEY=
SCORPIO_DEEPSEEK_API_KEY=
SCORPIO_XIAOMIMIMO_API_KEY=your_xiaomimimo_api_key_here
# GitHub Copilot uses OAuth/device flow — run `scorpio setup` to authorize. No key needed here.

# Financial Data
SCORPIO_FINNHUB_API_KEY=your-finnhub-key-here
SCORPIO_FRED_API_KEY=your-fred-api-key-here
SCORPIO_ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# Application Settings
SCORPIO_LOG_FORMAT=pretty

# Langfuse Observability (optional — enables OpenTelemetry tracing to Langfuse)
SCORPIO_LANGFUSE_PUBLIC_KEY=
SCORPIO_LANGFUSE_SECRET_KEY=
SCORPIO_LANGFUSE_BASE_URL=https://cloud.langfuse.com
